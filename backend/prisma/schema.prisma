generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int           @id @default(autoincrement())
  bin_iin              String        @unique
  user_type            String
  org_form             String
  organization_name    String
  registration_date    DateTime?
  director             String
  region               String
  district             String?
  rural_district       String?
  locality             String?
  phone                String?
  postal_address       String?
  email                String        @unique
  password_hash        String
  certificate_file_url String?
  createdAt            DateTime      @default(now())

  applications         Application[]
}

model Application {
  id                         Int      @id @default(autoincrement())
  userId                     Int
  applicantName              String
  region                     String
  subsidyProgram             String
  requestedAmount            Float
  landAreaHa                 Float?
  employeesCount             Int?
  annualRevenue              Float?
  taxDebt                    Float?   @default(0)
  creditDebt                 Float?   @default(0)
  priorViolationsCount3y     Int?     @default(0)
  priorRefundsCount3y        Int?     @default(0)
  pastApplicationsCount      Int?     @default(0)
  approvedSubsidiesCount     Int?     @default(0)

  score                      Float?
  priority                   String?
  riskFlags                  Json?
  recommendation             String?
  explanation                String?

  status                     String   @default("NEW") // NEW, REVIEW, APPROVED, REJECTED
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}